# --- Database (Neon / Supabase Postgres) ---
DATABASE_URL="postgresql://user:pass@host:5432/db?sslmode=require"

# --- Dashboard auth (single-user password gate for v1) ---
# Set this to any password; you'll type it on the /login page.
DASHBOARD_PASSWORD=""
# Used to sign the session cookie. Required.
NEXTAUTH_SECRET="generate with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# --- Meta app (for connecting FB Pages + IG accounts) ---
# Separate from NextAuth: we need long-lived Page tokens, not user login sessions.
META_APP_ID=""
META_APP_SECRET=""
META_OAUTH_REDIRECT_URI="http://localhost:3000/api/meta/oauth/callback"
META_GRAPH_API_VERSION="v21.0"

# --- Anthropic (classifier + translation) ---
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"

# --- Cron auth (Vercel Cron sets this header; we verify it) ---
CRON_SECRET="generate with: openssl rand -base64 32"

# --- Token encryption (Phase 3) ---
# 32-byte base64 key used to encrypt Meta access tokens at rest.
TOKEN_ENCRYPTION_KEY=""
